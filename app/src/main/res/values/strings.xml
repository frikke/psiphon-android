    <!-- NFC connection exchange onboarding / tutorial slide text -->
    <string name="psiphon_bump_help_1">If you are having trouble connecting to a Psiphon server, find a friend who has successfully connected and share their connection information using NFC.</string>

    <!-- NFC connection exchange onboarding / tutorial slide text, do not translate or transliterate 'Psiphon Bump' -->
    <string name="psiphon_bump_help_2">Make sure that Psiphon is open and connected and the Psiphon Bump icon is showing in the app bar on the other device.</string>

    <!-- NFC connection exchange onboarding / tutorial slide text, do not translate or transliterate 'Psiphon Bump' -->
    <string name="psiphon_bump_help_3">With the Psiphon Bump dialog open on your device and the Psiphon app open and connected on the other device, place your devices back to back to initiate a connection information data transfer.</string>

    <!-- NFC connection exchange onboarding / tutorial slide text, do not translate or transliterate 'Psiphon Bump'  -->
    <string name="psiphon_bump_help_4">Once the connection information data transfer is complete and your Psiphon app is able to connect, the Psiphon Bump dialog will close automatically. If you still cannot connect, you can retry until Psiphon connects successfully.</string>

