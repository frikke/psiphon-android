  <!--Title of the alert dialog which is shown to the user when they click toolbar notification of unsafe Internet traffic-->
  <string name="unsafe_traffic_alert_dialog_title">Psiphon MalAware</string>
  <!--Content of the alert dialog which is shown to the user when they click toolbar notification of unsafe Internet traffic-->
  <string name="unsafe_traffic_alert_dialog_message">Psiphon ಇಂಟರ್ನೆಟ್‌ನಲ್ಲಿ ಸಂಭಾವ್ಯ ಹಾನಿಕಾರಕ ಸೈಟ್‌ಗಳಿಗೆ ಪ್ರವೇಶವನ್ನು ಪತ್ತೆ ಮಾಡಿದೆ ಮತ್ತು ನಿರ್ಬಂಧಿಸಿದೆ. ಹೆಚ್ಚು ತಿಳಿಯಲು ದಯವಿಟ್ಟು ಕೆಳಗಿನ ಲಿಂಕ್‌ಗಳನ್ನು ಅನುಸರಿಸಿ.\n\nಪತ್ತೆಯಾದ ಮಾಲ್‌ವೇರ್:</string>
  <!--Title of the alert dialog which prompts the user to enable or disable unsafe Internet traffic alerts-->
  <string name="unsafe_traffic_alert_prompt_title">Psiphon MalAware</string>
  <!--Content of the alert dialog which prompts the user to enable or disable unsafe Internet traffic alerts-->
  <string name="unsafe_traffic_alert_prompt_message">Psiphon ಇಂಟರ್ನೆಟ್‌ನಲ್ಲಿ ಸಂಭಾವ್ಯ ಹಾನಿಕಾರಕ ಸೈಟ್‌ಗಳಿಗೆ ಪ್ರವೇಶವನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ನಿರ್ಬಂಧಿಸುತ್ತದೆ. ಇದು ಸಂಭವಿಸಿದಾಗ ನಿಮಗೆ ತಿಳಿಸಲು ನೀವು ಬಯಸುತ್ತೀರಾ?\n\nಈ ಸೆಟ್ಟಿಂಗ್ ಅನ್ನು ನಂತರ ಹೆಚ್ಚಿನ ಆಯ್ಕೆಗಳಲ್ಲಿ ಬದಲಾಯಿಸಬಹುದು.</string>
  <!--More info with a URL link in the contents of the alert dialog which prompts the user to enable or disable unsafe Internet traffic alerts-->
  <string name="unsafe_traffic_alert_prompt_message_more_info">MalAware ಬಗ್ಗೆ ಇಲ್ಲಿ ಇನ್ನಷ್ಟು ತಿಳಿಯಿರಿ:</string>
  <!--"Upstream proxy error" notification title-->
  <string name="notification_title_upstream_proxy_error">ಅಪ್‌ಸ್ಟ್ರೀಮ್ ಪ್ರಾಕ್ಸಿ ದೋಷ</string>
  <!--"Upstream proxy error" notification text-->
  <string name="notification_text_upstream_proxy_error">ದಯವಿಟ್ಟು Psiphon ತೆರೆಯಿರಿ ಮತ್ತು ಪ್ರಾಕ್ಸಿ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಪರಿಶೀಲಿಸಿ.</string>
  <!--"Upstream proxy error" alert dialog title-->
  <string name="upstream_proxy_error_alert_title">ಪ್ರಾಕ್ಸಿ ದೋಷ</string>
  <!--"Upstream proxy error" alert dialog message-->
  <string name="upstream_proxy_error_alert_message">ನೀವು ಅಪ್‌ಸ್ಟ್ರೀಮ್ ಪ್ರಾಕ್ಸಿ ಬಳಸಲು Psiphon ಅನ್ನು ಕಾನ್ಫಿಗರ್ ಮಾಡಿದ್ದೀರಿ. ಆದರೆ, ಆ ಪ್ರಾಕ್ಸಿ ಮೂಲಕ Psiphon ಸರ್ವರ್‌ಗೆ ಸಂಪರ್ಕಿಸಲು ನಮಗೆ ಸಾಧ್ಯವಾಗುತ್ತಿಲ್ಲ.\n\nದಯವಿಟ್ಟು ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಸರಿಪಡಿಸಿ ಮತ್ತು ಮತ್ತೆ ಪ್ರಯತ್ನಿಸಿ.\n\nತಾಂತ್ರಿಕ ಮಾಹಿತಿಗಾಗಿ ಲಾಗ್‌ಗಳನ್ನು ನೋಡಿ.</string>
  <!--Notification title for the 'Psiphon crash detected' notification-->
  <string name="psiphon_native_crash_notification_title">Psiphon ಕ್ರ್ಯಾಶ್ ಆಗಿದೆ</string>
  <!--Notification short message for the 'Psiphon crash detected' notification-->
  <string name="psiphon_native_crash_notification_msg">ದಯವಿಟ್ಟು ನಮಗೆ ಪ್ರತಿಕ್ರಿಯೆ ಕಳುಹಿಸಿ.</string>
  <!--Notification longer message for the 'Psiphon crash detected' notification-->
  <string name="psiphon_native_crash_notification_msg_long">ದಯವಿಟ್ಟು ನಮಗೆ ಪ್ರತಿಕ್ರಿಯೆ ಕಳುಹಿಸಲು ಈ ಅಧಿಸೂಚನೆಯನ್ನು ಕ್ಲಿಕ್ ಮಾಡಿ. ಇದು ನಮಗೆ ಸಮಸ್ಯೆಯನ್ನು ಅರ್ಥಮಾಡಿಕೊಳ್ಳಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ ಇದರಿಂದ ನಾವು ಅದನ್ನು ವೇಗವಾಗಿ ಸರಿಪಡಿಸಬಹುದು.</string>
  <!--Data collection disclosure prompt button text-->
  <string name="vpn_data_collection_disclosure_accept_btn_text">ನಾನು ಒಪ್ಪುತ್ತೇನೆ</string>
  <!--Data collection disclosure prompt title-->
  <string name="vpn_data_collection_disclosure_prompt_title">ಡೇಟಾ ಸಂಗ್ರಹಣೆ ಬಹಿರಂಗಪಡಿಸುವಿಕೆ</string>
  <!--First sentence of the data collection disclosure prompt body. The format qualifier %s will be replaced by the app name, either 'Psiphon' or 'Psiphon Pro' and should be placed according to the rules of the translation language.-->
  <string name="vpn_data_collection_disclosure_top">%s ಇಂಟರ್ನೆಟ್ ವಿಷಯಕ್ಕೆ ಸೆನ್ಸರ್ ಮಾಡದ ಪ್ರವೇಶವನ್ನು ಒದಗಿಸಲು Android VPN ಸೇವೆಯನ್ನು ಬಳಸುತ್ತದೆ. ನಾವು ಕೆಳಗಿನ ಮಾಹಿತಿಯನ್ನು ಸಂಗ್ರಹಿಸುತ್ತೇವೆ, ಸಂಯೋಜಿಸುತ್ತೇವೆ ಮತ್ತು ಸಂಗ್ರಹಿಸುತ್ತೇವೆ:</string>
  <!--Data collection disclosure list item-->
  <string name="vpn_data_collection_disclosure_bp1">ನಿಮ್ಮ ನಗರ, ದೇಶ, ISP ಮತ್ತು ಐಚ್ಛಿಕವಾಗಿ, ಅಂದಾಜು ಸ್ಥಳ. ನಗರ, ದೇಶ ಮತ್ತು ISP ಅನ್ನು ನೀವು ನಮ್ಮ ಸರ್ವರ್‌ಗಳಿಗೆ ಸಂಪರ್ಕಿಸುವ IP ವಿಳಾಸದಿಂದ ಪಡೆಯಲಾಗುತ್ತದೆ ಮತ್ತು IP ವಿಳಾಸವನ್ನು ಯಾವಾಗಲೂ ಲಾಗ್ ಮಾಡಲಾಗುವುದಿಲ್ಲ. ಈ ಡೇಟಾವನ್ನು ಬಳಕೆ ಮತ್ತು ಕಾರ್ಯಕ್ಷಮತೆಯ ಅಂಕಿಅಂಶಗಳು ಮತ್ತು ಸೇವಾ ಆರೋಗ್ಯ ಉದ್ದೇಶಗಳಿಗಾಗಿ ಸಂಗ್ರಹಿಸಲಾಗುತ್ತದೆ.</string>
  <!--Data collection disclosure list item-->
  <string name="vpn_data_collection_disclosure_bp2">ನೀವು ನಮಗೆ ರೋಗನಿರ್ಣಯ ಅಥವಾ ಕ್ರ್ಯಾಶ್ ಲಾಗ್ ಪ್ರತಿಕ್ರಿಯೆಯನ್ನು ಕಳುಹಿಸಿದಾಗ ನಿಮ್ಮ ಇಮೇಲ್. ಪ್ರತಿಕ್ರಿಯೆಯಲ್ಲಿ ಇಮೇಲ್ ಒದಗಿಸುವುದು ಐಚ್ಛಿಕವಾಗಿದೆ.</string>
  <!--Data collection disclosure list item-->
  <!--Notifications permission rationale alert title. The format qualifier %s will be replaced by the app name, either 'Psiphon' or 'Psiphon Pro' and should be placed according to the rules of the translation language.-->
  <string name="notifications_permission_rationale_title">%s ಅಧಿಸೂಚನೆಗಳು</string>
  <!--First sentence of the notifications permission rationale message. The format qualifier %s will be replaced by the app name, either 'Psiphon' or 'Psiphon Pro' and should be placed according to the rules of the translation language.-->
  <string name="notifications_permission_rationale_intro">%s ಅಪ್ಲಿಕೇಶನ್ ಹಿನ್ನೆಲೆಯಲ್ಲಿದ್ದಾಗ ಪ್ರಮುಖ ಮಾಹಿತಿಯನ್ನು ನಿಮಗೆ ಒದಗಿಸಲು ಅಧಿಸೂಚನೆಗಳನ್ನು ಬಳಸುತ್ತದೆ. ಇದು ಇವುಗಳನ್ನು ಒಳಗೊಂಡಿದೆ:</string>
