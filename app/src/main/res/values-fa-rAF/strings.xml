  <!--NFC connection exchange onboarding / tutorial slide text-->
  <string name="psiphon_bump_help_1">اگر در اتصال به سرور Psiphon مشکل دارید، دوستی که با موفقیت متصل شده پیدا کنید و اطلاعات اتصال آنها را با استفاده از NFC اشتراک کنید.</string>
  <!--NFC connection exchange onboarding / tutorial slide text, do not translate or transliterate 'Psiphon Bump'-->
  <string name="psiphon_bump_help_2">مطمئن شوید که Psiphon باز و متصل است و آیکون Psiphon Bump در نوار برنامه روی دستگاه دیگر نمایش داده می‌شود.</string>
  <!--NFC connection exchange onboarding / tutorial slide text, do not translate or transliterate 'Psiphon Bump'-->
  <string name="psiphon_bump_help_3">با دایلوگ Psiphon Bump باز روی دستگاه شما و برنامه Psiphon باز و متصل روی دستگاه دیگر، دستگاه‌های خود را پشت به پشت قرار دهید تا انتقال داده‌های اطلاعات اتصال آغاز شود.</string>
  <!--NFC connection exchange onboarding / tutorial slide text, do not translate or transliterate 'Psiphon Bump'-->
  <string name="psiphon_bump_help_4">پس از تکمیل انتقال داده‌های اطلاعات اتصال و قابل بودن اتصال برنامه Psiphon شما، دایلوگ Psiphon Bump به طور خودکار بسته می‌شود. اگر هنوز نمی‌توانید متصل شوید، می‌توانید تا زمانی که Psiphon با موفقیت متصل شود دوباره امتحان کنید.</string>
  <!--Title of the alert dialog prompting the user to enable NFC in system settings, do not translate or transliterate 'Psiphon Bump'-->
  <string name="psiphon_bump_need_system_nfc_title">Psiphon Bump</string>
  <!--Alert dialog message prompting the user to enable NFC in system settings, do not translate or transliterate 'Psiphon Bump'-->
