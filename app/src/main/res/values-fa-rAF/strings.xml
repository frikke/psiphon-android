  <string name="notifications_permission_rationale_intro">%s از اعلان‌ها استفاده می‌کند تا وقتی برنامه در پس‌زمینه است اطلاعات مهم را به شما ارائه دهد. این شامل:</string>
  <!--Notifications permission rationale list item-->
  <string name="notifications_permission_rationale_vpn_state_bp">تغییرات در وضعیت اتصال VPN شما.</string>
  <!--Notifications permission rationale list item-->
