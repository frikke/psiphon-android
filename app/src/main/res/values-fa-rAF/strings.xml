  <!--Content of the toolbar notification which is shown to the user when Psiphon server detects an unsafe Internet traffic-->
  <string name="unsafe_traffic_alert_notification_message">ترافیک بدافزار شناسایی شد! برای اطلاعات بیشتر کلیک کنید.</string>
  <!--Title of the alert dialog which is shown to the user when they click toolbar notification of unsafe Internet traffic-->
  <string name="unsafe_traffic_alert_dialog_title">Psiphon MalAware</string>
  <!--Content of the alert dialog which is shown to the user when they click toolbar notification of unsafe Internet traffic-->
  <string name="unsafe_traffic_alert_dialog_message">Psiphon دسترسی به سایت‌های احتمالی مخرب اینترنت را شناسایی و مسدود کرده است. لطفاً لینک‌های زیر را برای اطلاعات بیشتر دنبال کنید.\n\nبدافزار شناسایی شده:</string>
  <!--Title of the alert dialog which prompts the user to enable or disable unsafe Internet traffic alerts-->
  <string name="unsafe_traffic_alert_prompt_title">Psiphon MalAware</string>
  <!--Content of the alert dialog which prompts the user to enable or disable unsafe Internet traffic alerts-->
  <string name="unsafe_traffic_alert_prompt_message">Psiphon به طور خودکار دسترسی به سایت‌های احتمالی مخرب اینترنت را مسدود می‌کند. آیا می‌خواهید وقتی این اتفاق می‌افتد مطلع شوید؟\n\nاین تنظیم را می‌توان بعداً در گزینه‌های بیشتر تغییر داد.</string>
  <!--More info with a URL link in the contents of the alert dialog which prompts the user to enable or disable unsafe Internet traffic alerts-->
  <string name="unsafe_traffic_alert_prompt_message_more_info">در اینجا درباره MalAware بیشتر بیاموزید:</string>
  <!--"Upstream proxy error" notification title-->
  <string name="notification_title_upstream_proxy_error">خطای پراکسی بالادست</string>
  <!--"Upstream proxy error" notification text-->
  <string name="notification_text_upstream_proxy_error">لطفاً Psiphon را باز کرده و تنظیمات پراکسی را بررسی کنید.</string>
  <!--"Upstream proxy error" alert dialog title-->
  <string name="upstream_proxy_error_alert_title">خطای پراکسی</string>
  <!--"Upstream proxy error" alert dialog message-->
  <string name="upstream_proxy_error_alert_message">شما Psiphon را برای استفاده از پراکسی بالادست پیکربندی کرده‌اید. اما به نظر می‌رسد ما نمی‌توانیم از طریق آن پراکسی به سرور Psiphon متصل شویم.\n\nلطفاً تنظیمات را اصلاح کرده و دوباره امتحان کنید.\n\nاطلاعات فنی را در گزارش‌ها ببینید.</string>
  <!--Notification title for the 'Psiphon crash detected' notification-->
  <string name="psiphon_native_crash_notification_title">Psiphon کرش کرده است</string>
  <!--Notification short message for the 'Psiphon crash detected' notification-->
  <string name="psiphon_native_crash_notification_msg">لطفاً برای ما بازخورد ارسال کنید.</string>
  <!--Notification longer message for the 'Psiphon crash detected' notification-->
  <string name="psiphon_native_crash_notification_msg_long">لطفاً روی این اعلان کلیک کنید تا برای ما بازخورد ارسال کنید. این به ما کمک می‌کند مشکل را درک کنیم تا بتوانیم سریع‌تر آن را رفع کنیم.</string>
  <!--Data collection disclosure prompt button text-->
  <string name="vpn_data_collection_disclosure_accept_btn_text">می‌پذیرم</string>
  <!--Data collection disclosure prompt title-->
  <string name="vpn_data_collection_disclosure_prompt_title">افشای جمع‌آوری داده</string>
  <!--First sentence of the data collection disclosure prompt body. The format qualifier %s will be replaced by the app name, either 'Psiphon' or 'Psiphon Pro' and should be placed according to the rules of the translation language.-->
  <string name="vpn_data_collection_disclosure_top">%s از سرویس VPN اندروید استفاده می‌کند تا دسترسی بدون سانسور به محتوای اینترنت را برای شما فراهم کند. ما اطلاعات زیر را جمع‌آوری، تجمیع و ذخیره می‌کنیم:</string>
  <!--Data collection disclosure list item-->
  <string name="vpn_data_collection_disclosure_bp1">شهر، کشور، ISP شما و به صورت اختیاری، موقعیت تقریبی. شهر، کشور و ISP از آدرس IP که از آن به سرورهای ما متصل می‌شوید استخراج می‌شود و خود آدرس IP هرگز ثبت نمی‌شود. این داده‌ها برای آمار استفاده و عملکرد و اهداف سلامت سرویس جمع‌آوری می‌شوند.</string>
  <!--Data collection disclosure list item-->
  <string name="vpn_data_collection_disclosure_bp2">ایمیل شما، وقتی گزارش تشخیص یا کرش برای ما ارسال می‌کنید. ارائه ایمیل در بازخورد اختیاری است.</string>
  <!--Data collection disclosure list item-->
  <string name="vpn_data_collection_disclosure_bp3">تجربه استفاده شما، از جمله تعداد ارسال و دریافت داده‌هاو مدت زمان اتصال.</string>
